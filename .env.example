# === Auto Research Web - LLM Provider Configuration ===
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# --- Provider Selection ---
# Options: openai | anthropic | deepseek | openrouter
LLM_PROVIDER=deepseek

# --- Recommended: DeepSeek V4 Pro ---
# DeepSeek V4 Pro offers strong academic reasoning at competitive pricing.
# Recommended for academic research tasks.
LLM_API_KEY=your-deepseek-api-key
LLM_MODEL=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com/v1

# --- Alternative Providers ---

# OpenAI (GPT-4o, GPT-4.1, etc.)
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude Sonnet 4.6, Opus 4.7, etc.)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6
# LLM_BASE_URL=https://api.anthropic.com/v1

# OpenRouter (multi-provider gateway)
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-...
# LLM_MODEL=deepseek/deepseek-v4-pro
# LLM_BASE_URL=https://openrouter.ai/api/v1

# --- Default Parameters ---
# Temperature: lower = more deterministic (0.1-0.3 good for academic tasks)
DEFAULT_TEMPERATURE=0.3
# Max output tokens (8192 recommended for research/writing tasks)
DEFAULT_MAX_TOKENS=8192

# --- Server ---
PORT=3000
# For cross-domain deployments, set CORS_ORIGIN to your frontend URL:
# CORS_ORIGIN=https://jiang-524.github.io
