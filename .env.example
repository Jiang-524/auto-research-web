# === LLM Provider Configuration ===
# Choose one provider and fill in the required fields.
# The backend reads these at startup. Never commit real values.

LLM_PROVIDER=openai
# Options: openai | anthropic | deepseek | openrouter | custom

# --- OpenAI ---
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-6
# LLM_BASE_URL=https://api.anthropic.com/v1

# --- DeepSeek ---
# LLM_API_KEY=sk-...
# LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1

# --- OpenRouter or custom OpenAI-compatible endpoint ---
# LLM_API_KEY=sk-or-...
# LLM_MODEL=openai/gpt-4o
# LLM_BASE_URL=https://openrouter.ai/api/v1

# === Default parameters (optional) ===
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096

# === Server ===
PORT=3000
# Optional comma-separated browser origins allowed to call the backend when
# frontend and backend are deployed on different domains. Leave blank for
# same-origin/local backend use.
# CORS_ORIGIN=https://jiang-524.github.io,http://localhost:3000
