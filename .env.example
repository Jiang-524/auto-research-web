# === Auto Research Web - Local Research Bridge Configuration ===
# Copy this file to .env.local and fill in your credentials.
# Never commit .env.local to version control.

# --- Bridge Server ---
AUTO_RESEARCH_BRIDGE_PORT=8765
AUTO_RESEARCH_BRIDGE_HOST=127.0.0.1
AUTO_RESEARCH_ALLOWED_ORIGINS=https://jiang-524.github.io,http://localhost:5173,http://localhost:3000

# --- Workspace Paths ---
AUTO_RESEARCH_PROJECT_ROOT=E:/ccProject/researchWeb
AUTO_RESEARCH_WORKSPACE_ROOT=E:/ccProject/researchWeb
AUTO_RESEARCH_PAPER_DIR=E:/paper
AUTO_RESEARCH_DB_PATH=E:/ccProject/researchWeb/.auto-research/research.db
AUTO_RESEARCH_OUTPUT_DIR=E:/ccProject/researchWeb/.auto-research/outputs
AUTO_RESEARCH_INDEX_DIR=E:/ccProject/researchWeb/.auto-research/index
AUTO_RESEARCH_LOG_DIR=E:/ccProject/researchWeb/.auto-research/logs

# --- LLM Provider ---
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace_with_your_real_api_key

# --- Default LLM Parameters ---
DEFAULT_TEMPERATURE=0.3
DEFAULT_MAX_TOKENS=4096

# --- Legacy (kept for backward compatibility) ---
PORT=3000
CORS_ORIGIN=https://jiang-524.github.io,http://localhost:5173,http://localhost:3000
