# === Auto Research Web - Local Research Bridge Configuration ===
# Copy this file to .env.local and fill in your credentials.
# Never commit .env.local to version control.

# --- Bridge Server ---
AUTO_RESEARCH_BRIDGE_PORT=8765
AUTO_RESEARCH_BRIDGE_HOST=127.0.0.1
AUTO_RESEARCH_ALLOWED_ORIGINS=https://jiang-524.github.io,http://localhost:5173,http://localhost:3000

# --- Workspace Paths ---
# Replace /path/to/... with your own absolute local paths.
AUTO_RESEARCH_PROJECT_ROOT=/path/to/auto-research-web
AUTO_RESEARCH_WORKSPACE_ROOT=/path/to/auto-research-web
AUTO_RESEARCH_PAPER_DIR=/path/to/papers
AUTO_RESEARCH_DB_PATH=/path/to/auto-research-web/.auto-research/research.db
AUTO_RESEARCH_OUTPUT_DIR=/path/to/auto-research-web/.auto-research/outputs
AUTO_RESEARCH_INDEX_DIR=/path/to/auto-research-web/.auto-research/index
AUTO_RESEARCH_LOG_DIR=/path/to/auto-research-web/.auto-research/logs

# --- LLM Provider ---
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=replace_with_your_real_api_key

# --- Flash Model (fast/cheap for simple tasks: search, rough read, translate, format convert) ---
LLM_FLASH_MODEL=deepseek-v4-flash
LLM_FLASH_TEMPERATURE=0.1
LLM_FLASH_MAX_TOKENS=2048

# --- Default LLM Parameters ---
DEFAULT_TEMPERATURE=0.3
DEFAULT_MAX_TOKENS=8192

# --- Legacy (kept for backward compatibility) ---
PORT=3000
CORS_ORIGIN=https://jiang-524.github.io,http://localhost:5173,http://localhost:3000
